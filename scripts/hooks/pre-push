#!/usr/bin/env bash
# 阻止直接 push 到 main 分支——所有改动必须走 feature branch + PR。
# 远端 main 也启用了 GitHub 分支保护；本 hook 在本地提早拦截，给出明确指引。
#
# 安装：git config core.hooksPath scripts/hooks

set -euo pipefail

protected_branch="main"
exit_code=0

while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
        echo "" >&2
        echo "❌ 禁止直接 push 到 $protected_branch 分支" >&2
        echo "" >&2
        echo "   请使用 feature branch + PR 流程：" >&2
        echo "     git checkout -b feat/<task-id>-<slug>" >&2
        echo "     git push origin feat/<task-id>-<slug>" >&2
        echo "     gh pr create --base main" >&2
        echo "" >&2
        echo "   详见 CLAUDE.md § Git 工作流" >&2
        echo "" >&2
        exit_code=1
    fi
done

exit $exit_code
